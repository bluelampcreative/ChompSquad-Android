<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.ChompSquad" parent="android:Theme.Material.Light.NoActionBar" />

    <!--
        Splash screen theme — applied to MainActivity so the OS-managed splash
        is shown before Compose inflates. postSplashScreenTheme hands off to the
        main theme once the splash exits.

        windowSplashScreenBackground: solid brand-green matches the icon's radial
        gradient, so the edge of the RGBA PNG blends seamlessly into the canvas.
    -->
    <style name="Theme.ChompSquad.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#4AA448</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/chompsquad</item>
        <item name="postSplashScreenTheme">@style/Theme.ChompSquad</item>
    </style>

</resources>