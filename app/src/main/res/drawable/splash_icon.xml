<?xml version="1.0" encoding="utf-8"?>
<!--
    Splash screen icon wrapper.

    Android 12+ always masks the windowSplashScreenAnimatedIcon to a 240 dp
    circle inside a 288 dp canvas — content outside the circle is clipped.
    The 12.5 % inset on every side scales chompsquad.png to ~252 dp, which
    sits fully within the 240 dp safe zone with a small breathing margin.
    Adjust the inset value if the logo's own padding changes.
-->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/chompsquad"
    android:inset="12.5%" />
